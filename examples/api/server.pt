let userNames = ["Alice", "Bob"];
let userEmails = ["alice@example.com", "bob@example.com"];

fn json(status, data) {
  return {
    status: status,
    headers: {"Content-Type": "application/json"},
    body: toString(data)
  };
}

httpListen(3001, (req) => {
  show(req.method + " " + req.path);

  if (req.method is "OPTIONS") {
    return {status: 204, headers: {"Access-Control-Allow-Origin": "*"}};
  }

  if (req.path is "/api/users" and req.method is "GET") {
    let users = [];
    let i = 0;
    while (i < len(userNames)) {
      push(users, {id: i + 1, name: userNames[i], email: userEmails[i]});
      i++;
    }
    return json(200, users);
  }

  if (req.path is "/api/users" and req.method is "POST") {
    push(userNames, "New User");
    return json(201, {id: len(userNames), name: "New User"});
  }

  if (req.path is "/api/health") {
    return json(200, {status: "ok", uptime: "running"});
  }

  return json(404, {error: "Route not found"});
});
