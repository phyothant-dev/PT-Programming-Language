let statsUsers = 1234;
let statsRevenue = 56789;
let statsOrders = 456;

let orderIds = [1001, 1002, 1003];
let orderCustomers = ["Alice", "Bob", "Charlie"];
let orderAmounts = [99.99, 149.50, 29.99];
let orderStatuses = ["shipped", "pending", "delivered"];

httpListen(3000, (req) => {
  show(req.method + " " + req.path);

  if (req.path is "/") {
    return readFile("dashboard.html");
  }

  if (req.path is "/api/stats") {
    return {
      status: 200,
      headers: {"Content-Type": "application/json"},
      body: toString({users: statsUsers, revenue: statsRevenue, orders: statsOrders})
    };
  }

  if (req.path is "/api/orders") {
    let orders = [];
    let i = 0;
    while (i < len(orderIds)) {
      push(orders, {id: orderIds[i], customer: orderCustomers[i], amount: orderAmounts[i], status: orderStatuses[i]});
      i++;
    }
    return {
      status: 200,
      headers: {"Content-Type": "application/json"},
      body: toString(orders)
    };
  }

  return {status: 404, body: "{\"error\": \"Not Found\"}"};
});
