// Benchmark 4: Array push + iterate (100_000 items)
let arr = [];
let i = 0;
let start = clock();
while (i < 100000) {
  push(arr, i * 2);
  i++;
}
let sum = 0;
i = 0;
while (i < len(arr)) {
  sum += arr[i];
  i++;
}
let elapsed = clock() - start;
show("Sum: " + toString(sum));
show("Time: " + toString(elapsed) + "s");
