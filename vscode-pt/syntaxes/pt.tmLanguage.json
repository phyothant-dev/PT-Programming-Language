{
  "scopeName": "source.pt",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#strings" },
    { "include": "#interpolation" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#types" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.pt",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.pt",
          "match": "\\b(if|else|unless|while|for|loop|break|continue|return|try|catch|finally|throw)\\b"
        },
        {
          "name": "keyword.declaration.pt",
          "match": "\\b(let|var|const|fn|import|as)\\b"
        },
        {
          "name": "keyword.operator.logical.pt",
          "match": "\\b(and|or|is|isnt)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.pt",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.pt",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.pt",
              "match": "\\\\(n|t|r|\\\\|\")"
            }
          ]
        }
      ]
    },
    "interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.pt",
          "match": "\\$\\{[^}]*\\}",
          "patterns": [
            {
              "name": "punctuation.definition.interpolation.begin.pt",
              "match": "\\$\\{"
            },
            {
              "name": "punctuation.definition.interpolation.end.pt",
              "match": "\\}"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.pt",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.pt",
          "match": "=|\\+=|-=|\\*=|/=|%=|=>"
        },
        {
          "name": "keyword.operator.comparison.pt",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.pt",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.ternary.pt",
          "match": "\\?|:"
        },
        {
          "name": "keyword.operator.unary.pt",
          "match": "!"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.pt",
          "match": "\\b(show|print|len|push|pop|toNum|toString|type|input|assert|clock|random|readFile|writeFile|upper|lower|trim|substr|contains|replace|split|join|indexOf|abs|sqrt|min|max|floor|ceil|round|sort|range|map|filter|reduce|keys|values|has)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.pt",
          "match": "\\b(number|string|array|map|function|nil)\\b"
        }
      ]
    }
  }
}
